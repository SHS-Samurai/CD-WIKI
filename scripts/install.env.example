# Nach /root/cd-wiki-install.env kopieren, Werte setzen und chmod 600 ausfuehren.
# Erlaubt sind ausschliesslich die vorgegebenen NAME="Wert"-Zeilen.

DOMAIN="wiki.only-space.de"
LETSENCRYPT_EMAIL="admin@example.invalid"

SMTP_HOST="smtp.example.invalid"
SMTP_PORT="587"
SMTP_USER="wiki@example.invalid"
SMTP_PASSWORD="change-me"
SMTP_USE_TLS="true"
SMTP_USE_SSL="false"
DEFAULT_FROM_EMAIL="wiki@example.invalid"

ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.invalid"
ADMIN_PASSWORD="change-this-to-at-least-16-characters"

# Vollstaendiger Commit, der auf dem Server ausgecheckt werden soll.
EXPECTED_GIT_COMMIT="replace-with-40-character-git-commit"

# Version und SHA-256 immer direkt auf der offiziellen GitHub-Release-Seite pruefen.
MEILISEARCH_VERSION="vX.Y.Z"
MEILISEARCH_SHA256="replace-with-64-character-sha256"
